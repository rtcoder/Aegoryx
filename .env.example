APP_NAME=Aegoryx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://aegoryx.test
LANDLORD_DOMAIN=admin.aegoryx.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=aegoryx
DB_USERNAME=postgres
DB_PASSWORD=
DB_QUERY_LOG=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
DB_QUEUE_CONNECTION=pgsql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AEGORYX_QUEUE_SYSTEM=system
AEGORYX_QUEUE_TENANT=tenant
AEGORYX_QUEUE_EXPORTS=exports
AEGORYX_QUEUE_DEFAULT=default
HORIZON_NAME=Aegoryx
HORIZON_DOMAIN=
HORIZON_PATH=horizon

RETENTION_ACTIVITY_ENTRIES_DAYS=365
RETENTION_AUDIT_LOGS_DAYS=730
RETENTION_DELETED_FILES_DAYS=30
RETENTION_EXPORT_FILES_EXPIRE_HOURS=24

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
